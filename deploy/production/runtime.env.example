# PR-134 runtime secret mount example.
# Copy outside git-managed paths and provide through Docker/secret manager only.
# Do not store real credentials here.

PAPER_TRADING_ONLY=true
LIVE_TRADING_ENABLED=false
JITO_ENABLED=false
KAMINO_LIQUIDATION_ENABLED=false
FLASHLOAN_RUNTIME_STATE_PATH=/run/flashloan-bot/runtime.json
FLASHLOAN_HEALTH_HOST=127.0.0.1
FLASHLOAN_HEALTH_PORT=8080
FLASHLOAN_HEALTH_URL=http://127.0.0.1:8080/health

# RPC/provider credentials must be mounted from a secret manager or local secret file
# outside the repository. Keep these as references/placeholders only.
SOLANA_RPC_URL=
HELIUS_API_KEY=
JUPITER_API_KEY=
JITO_AUTH_TOKEN=
