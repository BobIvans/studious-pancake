# Legacy-safe defaults for tests and quarantined scripts.
# The supported `python arb_bot.py` entrypoint does not use these flags to promote capabilities.
PAPER_TRADING_ONLY=true
LIVE_TRADING_ENABLED=false
JITO_ENABLED=false
KAMINO_LIQUIDATION_ENABLED=false

# Clean install and verification:
# python3.13 -m venv .venv
# source .venv/bin/activate
# python -m pip install --upgrade pip setuptools wheel
# python -m pip install -r requirements.txt
# make verify

# Optional RPC settings for manual tests and quarantined modules only.
SOLANA_RPC_HTTP=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com
WEBHOOK_PORT=3000

# PR-195 typed secret references. Values point to owner-only files or an
# external secret store; raw API keys/passphrases are intentionally not shown.
FLASHLOAN_HELIUS_API_KEY_REFERENCE=
FLASHLOAN_HELIUS_WEBHOOK_AUTH_REFERENCE=
FLASHLOAN_JUPITER_API_KEY_REFERENCE=
FLASHLOAN_OKX_API_KEY_REFERENCE=
FLASHLOAN_OKX_SECRET_KEY_REFERENCE=
FLASHLOAN_OKX_API_PASSPHRASE_REFERENCE=
FLASHLOAN_JITO_AUTH_REFERENCE=

# PR-195 endpoint origins are origins only; REST/RPC paths are owned by adapters.
FLASHLOAN_JUPITER_BASE_URL=https://api.jup.ag
FLASHLOAN_JITO_BASE_URL=https://mainnet.block-engine.jito.wtf
FLASHLOAN_OKX_BASE_URL=https://web3.okx.com
FLASHLOAN_HELIUS_BASE_URL=https://mainnet.helius-rpc.com

# MarginFi fixture/manual configuration. Not proof of live readiness.
MARGINFI_ACCOUNT=your_marginfi_account_pubkey_here
MARGINFI_SOL_BANK=CCwqExrqLGHtq12X182rFvA4KEDtK13q2E7B3Jp2Cxyj
MARGINFI_USDC_BANK=2s37akK2eyBbp8DZgCm7RtsaEz8eWhVKGfHGA3cKMEW2

# Legacy quarantined scripts may still read these numeric knobs, but active
# runtime economics must use integer lamports/quantities from typed config.
MIN_LIQUIDITY_SOL=1.0
NEW_POOLS_LOOKBACK_HOURS=24
FLASHLOAN_AMOUNT_USDC=1000
FLASHLOAN_AMOUNT_SOL=5.0
MIN_PROFIT_THRESHOLD_SOL=0.001
MIN_PROFIT_THRESHOLD_USDC=0.01
ARBITRAGE_TIMEOUT_SECONDS=30
MAX_CONCURRENT_ARBITRAGES=3
JITO_TIP_STREAM_URL=https://bundles.jito.wtf/api/v1/bundles/tip_stream
JITO_SNIPER_ENABLED=false
JITO_TIP_PERCENTILE=75.0
JITO_MIN_TIP_LAMPORTS=10000
MULTI_RPC_ENABLED=false
MULTI_RPC_1=wss://api.mainnet-beta.solana.com
MULTI_RPC_2=wss://api.mainnet-beta.solana.com
MULTI_RPC_3=wss://api.mainnet-beta.solana.com
MULTI_RPC_4=wss://api.mainnet-beta.solana.com

# Deprecated raw-secret variables are deliberately absent. PR-195 rejects raw
# OKX_PASSPHRASE/OKX_API_PASSPHRASE, JUPITER_API_KEY and HELIUS_API_KEY values
# in product-contract validation; use *_REFERENCE variables above instead.
ROUTE_DISCOVERY_ENABLED=false
OKX_EXECUTION_PROMOTION_ENABLED=false
