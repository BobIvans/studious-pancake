{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PR-112 redacted credential incident manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "incident_id",
    "opened_at",
    "entries",
    "review"
  ],
  "properties": {
    "schema_version": {
      "const": "pr112.credential-incident-manifest.v1"
    },
    "incident_id": {
      "type": "string",
      "minLength": 8
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "credential_alias",
          "detected_location",
          "rotation_status",
          "usage_review_status"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "minLength": 2
          },
          "credential_alias": {
            "type": "string",
            "description": "Operator-visible alias only; no credential material."
          },
          "detected_location": {
            "type": "string",
            "description": "Path or artifact label only."
          },
          "rotation_status": {
            "enum": [
              "revoked",
              "rotated",
              "confirmed-inactive",
              "pending-operator-action"
            ]
          },
          "usage_review_status": {
            "enum": [
              "reviewed-no-unknown-usage",
              "reviewed-followup-required",
              "pending-operator-action"
            ]
          },
          "rotated_at": {
            "type": "string",
            "format": "date-time"
          },
          "reviewer": {
            "type": "string"
          },
          "notes": {
            "type": "string",
            "description": "Redacted operational note."
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "history_scan_status",
        "artifact_invalidation_status",
        "approved_by"
      ],
      "properties": {
        "history_scan_status": {
          "enum": [
            "passed-after-purge",
            "pending-operator-action"
          ]
        },
        "artifact_invalidation_status": {
          "enum": [
            "completed",
            "pending-operator-action"
          ]
        },
        "approved_by": {
          "type": "string"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
