[flake8]
# The repository contains large legacy scripts that predate the CI lint gate.
# Keep syntax checking in the dedicated compileall job and make flake8 focus on
# actionable formatting in newly maintained code until the legacy tree is
# incrementally cleaned up.
max-line-length = 140
extend-ignore =
    C901,
    E111,
    E117,
    E121,
    E122,
    E126,
    E127,
    E128,
    E131,
    E203,
    E225,
    E227,
    E221,
    E226,
    E231,
    E241,
    E261,
    E265,
    E301,
    E302,
    E303,
    E305,
    E306,
    E401,
    E402,
    E501,
    F401,
    F402,
    F403,
    F405,
    F541,
    F811,
    F824,
    F841,
    E252,
    E701,
    E702,
    E741,
    W291,
    W292,
    W293,
    W391,
    W503,
    W504


# PR-024: only the non-importable legacy monolith may retain its existing
# undefined-name debt. Active code is not allowed to suppress F821 globally.
per-file-ignores =
    src/legacy_arb_bot.py:F821
