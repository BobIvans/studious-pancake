[flake8]
# The repository contains large legacy scripts that predate the CI lint gate.
# Keep syntax checking in the dedicated compileall job and make flake8 focus on
# actionable formatting in newly maintained code until the legacy tree is
# incrementally cleaned up.
max-line-length = 140
extend-ignore =
    C901,
    E111,
    E117,
    E121,
    E122,
    E126,
    E127,
    E128,
    E131,
    E203,
    E221,
    E226,
    E231,
    E241,
    E261,
    E302,
    E303,
    E305,
    E306,
    E401,
    E402,
    E501,
    F401,
    F402,
    F541,
    F811,
    F821,
    F824,
    F841,
    W291,
    W292,
    W293,
    W391,
    W503,
    W504
