{
  "schema_version": "pr043.security-supply-chain-policy.v1",
  "dependency_audit": {
    "block_at_or_above": "critical",
    "fail_unknown_severity": true,
    "allowlist": []
  },
  "sbom": {
    "required_for_production_image": true,
    "accepted_formats": ["cyclonedx-json", "spdx-json"]
  },
  "image_provenance": {
    "signed_image_required_for_production": true,
    "provenance_attestation_required": true
  },
  "license_inventory": {
    "required_for_release_candidate": true,
    "manual_review_required_for_unknown_license": true
  }
}
