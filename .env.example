# Legacy-safe defaults for tests and quarantined scripts.
# The supported `python arb_bot.py` entrypoint does not use these flags to promote capabilities.
PAPER_TRADING_ONLY=true
LIVE_TRADING_ENABLED=false
JITO_ENABLED=false
KAMINO_LIQUIDATION_ENABLED=false

# Clean install and verification:
# python3.13 -m venv .venv
# source .venv/bin/activate
# python -m pip install --upgrade pip setuptools wheel
# python -m pip install -r requirements.txt
# make verify

# Optional RPC/API settings for manual tests and quarantined modules only.
SOLANA_RPC_HTTP=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_SENDER_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
WEBHOOK_PORT=3000

# MarginFi fixture/manual configuration. Not proof of live readiness.
MARGINFI_ACCOUNT=your_marginfi_account_pubkey_here
MARGINFI_SOL_BANK=CCwqExrqLGHtq12X182rFvA4KEDtK13q2E7B3Jp2Cxyj
MARGINFI_USDC_BANK=2s37akK2eyBbp8DZgCm7RtsaEz8eWhVKGfHGA3cKMEW2

MIN_LIQUIDITY_SOL=1.0
NEW_POOLS_LOOKBACK_HOURS=24
FLASHLOAN_AMOUNT_USDC=1000
FLASHLOAN_AMOUNT_SOL=5.0
MIN_PROFIT_THRESHOLD_SOL=0.001
MIN_PROFIT_THRESHOLD_USDC=0.01
ARBITRAGE_TIMEOUT_SECONDS=30
MAX_CONCURRENT_ARBITRAGES=3
JITO_RPC_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_TIP_STREAM_URL=https://bundles.jito.wtf/api/v1/bundles/tip_stream
JITO_SNIPER_ENABLED=false
JITO_TIP_PERCENTILE=75.0
JITO_MIN_TIP_LAMPORTS=10000
MULTI_RPC_ENABLED=false
MULTI_RPC_1=wss://api.mainnet-beta.solana.com
MULTI_RPC_2=wss://api.mainnet-beta.solana.com
MULTI_RPC_3=wss://api.mainnet-beta.solana.com
MULTI_RPC_4=wss://api.mainnet-beta.solana.com

# PR-012 provider discovery/router credentials (blank values keep providers disabled or paper-safe).
JUPITER_API_KEY=
OKX_API_KEY=
OKX_PASSPHRASE=
OKX_SECRET_KEY=
OPENOCEAN_API_KEY=
