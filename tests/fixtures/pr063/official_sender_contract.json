{
  "schema": "pr063.canonical-sender-contract.v1",
  "solana": {
    "submit_method": "sendTransaction",
    "status_method": "getSignatureStatuses",
    "encoding": "base64",
    "successful_submit_is_landing_proof": false
  },
  "jito": {
    "base_url": "https://mainnet.block-engine.jito.wtf",
    "single_path": "/api/v1/transactions",
    "bundle_path": "/api/v1/bundles",
    "inflight_path": "/api/v1/getInflightBundleStatuses",
    "bundle_status_path": "/api/v1/getBundleStatuses",
    "tip_accounts_path": "/api/v1/getTipAccounts",
    "default_send_requires_auth": false,
    "uuid_header": "x-jito-auth",
    "bundle_transaction_min": 1,
    "bundle_transaction_max": 5,
    "status_id_max": 5,
    "minimum_tip_lamports": 1000
  },
  "safety": {
    "permit_bound_only": true,
    "exactly_one_tip": true,
    "transport_fallback": false,
    "automatic_duplicate_submission": false
  }
}
